{
  "name": "gymbro-backend",
  "version": "1.0.0",
  "description": "GymBro AI Fitness Trainer Backend",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:client": "npm --prefix ../frontend install && npm --prefix ../frontend run build && node scripts/copyClient.js",
    "build:full": "npm run build && npm run build:client",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.10",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^9.14.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/services/**/*.ts",
      "src/controllers/**/*.ts",
      "src/middleware/**/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}
